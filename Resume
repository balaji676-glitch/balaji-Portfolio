<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Balaji P · Resume</title>
    <!-- Font Awesome for icons -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Inter', system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
        }

        body {
            background: #0b0b15;
            background: radial-gradient(circle at 10% 20%, #16162a, #080810);
            min-height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            padding: 2rem 1.5rem;
        }

        /* main resume card */
        .resume-document {
            max-width: 1000px;
            width: 100%;
            background: rgba(18, 20, 28, 0.9);
            backdrop-filter: blur(14px);
            -webkit-backdrop-filter: blur(14px);
            border: 1px solid rgba(70, 130, 255, 0.25);
            border-radius: 2.8rem;
            box-shadow: 0 30px 60px rgba(0, 0, 0, 0.7), 0 0 0 1px rgba(90, 140, 255, 0.2) inset;
            padding: 2.5rem;
        }

        /* resume icon header */
        .resume-badge {
            display: flex;
            align-items: center;
            gap: 10px;
            margin-bottom: 1.5rem;
            padding-bottom: 1rem;
            border-bottom: 1px dashed rgba(255,255,255,0.1);
        }

        .resume-badge i {
            font-size: 2rem;
            color: #3b82f6;
            background: rgba(59,130,246,0.15);
            padding: 0.8rem;
            border-radius: 50%;
            border: 1px solid rgba(59,130,246,0.4);
        }

        .resume-badge span {
            font-size: 1.8rem;
            font-weight: 500;
            color: #e0e7ff;
        }

        .resume-badge small {
            color: #8a9cd3;
            margin-left: auto;
            font-size: 0.9rem;
            background: #1e2538;
            padding: 0.4rem 1.2rem;
            border-radius: 40px;
            border: 1px solid #2d3b5a;
        }

        /* name and title */
        .name-title {
            margin-bottom: 2rem;
        }

        .name-title h1 {
            font-size: 3.2rem;
            font-weight: 700;
            background: linear-gradient(to right, #fff, #b3cbff);
            -webkit-background-clip: text;
            background-clip: text;
            color: transparent;
            line-height: 1.1;
        }

        .name-title .sub {
            font-size: 1.2rem;
            color: #99ace4;
            display: flex;
            align-items: center;
            gap: 0.8rem;
            margin-top: 0.3rem;
        }

        .name-title .sub i {
            background: #1f2740;
            padding: 0.2rem 0.9rem;
            border-radius: 30px;
            font-style: normal;
            border: 1px solid #314671;
            color: #ccdcff;
        }

        /* summary section */
        .summary {
            background: rgba(10, 12, 25, 0.7);
            border-radius: 2rem;
            padding: 1.8rem 2rem;
            margin-bottom: 2.5rem;
            border: 1px solid #202842;
            font-size: 1.1rem;
            line-height: 1.7;
            color: #cad2f0;
        }

        .summary i {
            color: #3b82f6;
            margin-right: 0.5rem;
        }

        /* two column layout */
        .resume-columns {
            display: grid;
            grid-template-columns: 1.6fr 1fr;
            gap: 2rem;
        }

        /* section headings */
        .sec-head {
            display: flex;
            align-items: center;
            gap: 10px;
            font-size: 1.3rem;
            font-weight: 600;
            color: white;
            border-left: 4px solid #3b82f6;
            padding-left: 1rem;
            margin-bottom: 1.5rem;
        }

        .sec-head i {
            color: #3b82f6;
        }

        /* experience cards */
        .exp-card {
            background: rgba(20, 22, 36, 0.6);
            border-radius: 1.8rem;
            padding: 1.6rem;
            margin-bottom: 1.5rem;
            border: 1px solid rgba(255,255,255,0.02);
        }

        .exp-header {
            display: flex;
            flex-wrap: wrap;
            justify-content: space-between;
            align-items: baseline;
            margin-bottom: 0.8rem;
        }

        .exp-header h3 {
            color: white;
            font-size: 1.3rem;
        }

        .exp-header .tag {
            background: #141d33;
            color: #b1c6ff;
            border-radius: 30px;
            padding: 0.2rem 1rem;
            border: 1px solid #2a3a60;
            font-size: 0.8rem;
        }

        .exp-desc {
            list-style: none;
        }

        .exp-desc li {
            display: flex;
            gap: 0.8rem;
            color: #b7c3e3;
            font-size: 0.98rem;
            margin-bottom: 0.8rem;
        }

        .exp-desc li i {
            color: #3b82f6;
            width: 1.2rem;
            margin-top: 0.2rem;
        }

        .proof {
            margin-top: 0.5rem;
            font-size: 0.85rem;
            background: #0e1629;
            display: inline-block;
            padding: 0.2rem 1rem 0.2rem 0.8rem;
            border-radius: 30px;
            border: 1px dashed #3b82f6;
        }

        .proof a {
            color: #a7baff;
            text-decoration: none;
            border-bottom: 1px dotted;
        }

        /* project block */
        .project-block {
            background: rgba(20, 22, 36, 0.6);
            border-radius: 1.8rem;
            padding: 1.6rem;
            border: 1px solid rgba(255,255,255,0.02);
        }

        .project-block h3 {
            color: white;
            font-size: 1.4rem;
            margin-bottom: 0.3rem;
        }

        .project-tag {
            background: #19233f;
            color: #adc4ff;
            border-radius: 40px;
            padding: 0.2rem 1rem;
            display: inline-block;
            margin: 0.5rem 0 0.8rem;
            border: 1px solid #314e8a;
        }

        .project-desc {
            color: #b5c5f0;
            margin-bottom: 1rem;
        }

        .project-link {
            color: #6d9eff;
            text-decoration: none;
            font-weight: 500;
            display: inline-flex;
            align-items: center;
            gap: 5px;
        }

        /* skills block */
        .skill-block {
            background: rgba(20, 22, 36, 0.6);
            border-radius: 2rem;
            padding: 1.8rem;
            margin-bottom: 1.8rem;
            border: 1px solid #1f253e;
        }

        .skill-cat {
            margin-bottom: 1.4rem;
        }

        .skill-cat h4 {
            color: #b1c2f0;
            font-size: 0.95rem;
            text-transform: uppercase;
            letter-spacing: 1px;
            margin-bottom: 0.7rem;
            opacity: 0.8;
        }

        .skill-items {
            display: flex;
            flex-wrap: wrap;
            gap: 0.5rem;
        }

        .skill-items span {
            background: #171f32;
            padding: 0.3rem 1.1rem;
            border-radius: 40px;
            border: 1px solid #2b385b;
            color: #cbd6ff;
            font-size: 0.9rem;
        }

        /* certifications */
        .cert-item {
            display: flex;
            align-items: center;
            gap: 1rem;
            margin-bottom: 1rem;
            color: #c1cef5;
        }

        .cert-item i {
            color: #3b82f6;
            width: 1.4rem;
        }

        .cert-item a {
            color: #b1c2fc;
            text-decoration: none;
            border-bottom: 1px dotted #3b82f6;
        }

        /* education */
        .edu-item {
            display: flex;
            gap: 1rem;
            background: rgba(20, 22, 36, 0.6);
            border-radius: 1.8rem;
            padding: 1.5rem;
        }

        .edu-item i {
            font-size: 2rem;
            color: #3b82f6;
        }

        .edu-text h3 {
            color: white;
            font-weight: 600;
        }

        .edu-text p {
            color: #9aafe0;
        }

        /* footer */
        .resume-footer-note {
            margin-top: 2.5rem;
            text-align: center;
            color: #506394;
            font-size: 0.9rem;
            border-top: 1px dashed #262e48;
            padding-top: 1.5rem;
        }

        .resume-footer-note i {
            color: #3b82f6;
            margin: 0 5px;
        }

        /* responsive */
        @media (max-width: 750px) {
            .resume-columns { grid-template-columns: 1fr; }
            .resume-document { padding: 1.8rem; }
            .name-title h1 { font-size: 2.5rem; }
        }
    </style>
</head>
<body>
